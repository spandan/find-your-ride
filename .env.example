# =============================================================================
# Local development
# =============================================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/school_pickup_map"
SESSION_SECRET="change-me-to-a-long-random-string"

# =============================================================================
# Railway (https://railway.com)
# =============================================================================
# 1. Create a new project and add a PostgreSQL plugin
# 2. Add this repo as a service (GitHub: spandan/find-your-ride)
# 3. Link Postgres → your web service (Railway injects DATABASE_URL automatically)
# 4. Set SESSION_SECRET in the web service variables (long random string)
# 5. Deploy — migrations run on startup via `npm run railway:start`
#
# Do NOT use prisma+postgres:// on Railway. Use the Postgres plugin URL:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
# SSL is handled automatically on Railway (sslmode=no-verify for Node pg).
#
# Optional: set NODE_ENV=production (Railway sets this automatically)
# RAILWAY_ENVIRONMENT is set automatically by Railway
